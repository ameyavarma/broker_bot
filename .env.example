# Copy this file to ".env" and fill in your own values.

# IBKR connection
# Port: 7497 = paper TWS, 7496 = live TWS, 4002 = paper Gateway, 4001 = live Gateway
# options_order.py asks paper-or-live at startup and picks its port itself
# (IB_PORT_PAPER / IB_PORT_LIVE below); IB_PORT is used by the scripts that
# don't ask (portfolio.py, snapshot.py).
IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=1
# Optional overrides, only needed for non-standard TWS/Gateway port setups:
#IB_PORT_PAPER=7497
#IB_PORT_LIVE=7496
# Your account id. Paper accounts start with "DU", live accounts with "U".
# Only used to FILTER data requests (positions/account summary) when one login
# manages several accounts -- leave blank for a normal single-account login.
# portfolio.py asks "Account ID to pull?" at startup; this value pre-fills
# that prompt, so set it to the account you pull most (e.g. the main fund).
IB_ACCOUNT=

# Where CSV files are written (relative to project root)
OUTPUT_SNAPSHOTS_DIR=output_snapshots
OUTPUT_PORTFOLIO_DIR=output_portfolio

# Tickers to pull market data for (comma-separated)
WATCHLIST=AAPL,MSFT,SPY
